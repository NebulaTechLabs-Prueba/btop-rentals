# Base URL path the app is served from.
#   "/"                    → domain root (Hetzner / Nginx, default)
#   "/btop-admin-demo/"    → GitHub Pages subpath (set by the Pages workflow)
BASE_PATH=/

# Supabase (production backend). Frontend only ever uses the anon/public key.
# Leave BLANK to keep running on localStorage (current behavior).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Edge Functions / API) — NEVER expose in the frontend:
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
